$outdir/monitor.log" 2>/dev/null || printf 'monitor.log missing\n'     echo "[process after wait]"     ps -ef | grep '[a]gent-app' || printf 'no agent-app process\n'   }   run_oom_case 128 memory-128   run_oom_case 256 memory-256   rc=$?   echo "[exit] $rc"   echo "interpretation: 두 MEMORY_LIMIT 조건의 앱 로그와 monitor.log로 메모리 증가, MemoryGuard 종료, 생존 시간 차이를 판단한다."   echo "===== WORK LOG BLOCK END =====" } >> codex-harness/tasks/mission1_2/runtime/work.log printf 'OOM 128/256 비교 실행 완료. 전체 로그: runtime/work.log\n'
